{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@backspace/api": "workspace:*",
    "@backspace/auth": "workspace:*",
    "@backspace/db": "workspace:*",
    "@backspace/env": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@backspace/config": "workspace:*",
    "@types/node": "^22.13.14",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "catalog:"
  }
}
